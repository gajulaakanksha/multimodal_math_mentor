# Groq API Key (get from https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Optional: Whisper model size (tiny | base | small) — tiny is fastest, base is more accurate
WHISPER_MODEL=base

# Optional: EasyOCR language list (comma-separated)
OCR_LANGUAGES=en

# Optional: Number of RAG chunks to retrieve
RAG_TOP_K=5

# Optional: Verifier confidence threshold to trigger HITL (0.0 - 1.0)
HITL_CONFIDENCE_THRESHOLD=0.75
